Amount = int(input("What is the amount of money you want to withdraw? : "))

note_100 = Amount // 100
note_50 = (Amount % 100) // 50
note_10 = (Amount % 50) // 10

print("The number of 100 dollar notes you will receive are:", note_100)
print("The number of 50 dollar notes you will receive are:", note_50)
print("The number of 10 dollar notes you will receive are:", note_10)
