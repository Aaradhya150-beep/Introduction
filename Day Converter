days = int(input("Enter a number of days so I can convert it into years, months, and weeks:"))

years = days // 365
remaining_days = days % 365

months = remaining_days // 30
remaining_days %= 30

weeks = remaining_days // 7
remaining_days %= 7

print("The number of years is:", years)
print("The number of months is:", months)
print("The number of weeks is:", weeks)
print("The number of days is:", remaining_days)